{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/feedback.ts": {
      "maxDuration": 300
    },
    "api/pre-check.ts": {
      "maxDuration": 30
    },
    "api/retention-check.ts": {
      "maxDuration": 30
    },
    "api/check-practice.ts": {
      "maxDuration": 30
    }
  }
}
